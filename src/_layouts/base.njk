<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — Kayla Victoria Bennett</title>
<meta name="description" content="{{ description or 'Political science student. Conservative commentator. Creator of Linine. Georgetown, Washington D.C.' }}">
<meta name="keywords" content="{{ keywords or 'Kayla Victoria Bennett, conservative blog, politics technology, Georgetown DC, Linine AI model' }}">
<link rel="canonical" href="https://kaylavbennett.com{{ page.url }}">

<meta property="og:title" content="{{ title }} — Kayla Victoria Bennett">
<meta property="og:description" content="{{ description or 'Political science student. Conservative commentator. Creator of Linine.' }}">
<meta property="og:image" content="{{ ogImage or 'https://kaylavbennett.com/img/og-kayla.jpg' }}">
<meta property="og:url" content="https://kaylavbennett.com{{ page.url }}">
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:site_name" content="Kayla Victoria Bennett">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }} — Kayla Victoria Bennett">
<meta name="twitter:description" content="{{ description or 'Politics. Technology. The American Dream.' }}">

<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%230B1F3A'/><text x='50%25' y='54%25' dominant-baseline='central' text-anchor='middle' font-family='Georgia,serif' font-size='18' fill='%23C9A84C'>K</text></svg>">

{% if author == "linine" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "datePublished": "{{ page.date | machineDate }}",
  "author": { "@type": "Person", "name": "Linine", "url": "https://linine.synthgallery.com" },
  "publisher": { "@type": "Organization", "name": "Kayla Victoria Bennett", "url": "https://kaylavbennett.com" }
}
</script>
{% else %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "datePublished": "{{ page.date | machineDate }}",
  "author": { "@type": "Person", "name": "Kayla Victoria Bennett", "url": "https://kaylavbennett.com" },
  "publisher": { "@type": "Organization", "name": "Kayla Victoria Bennett", "url": "https://kaylavbennett.com" }
}
</script>
{% endif %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/main.css">
{% block extrahead %}{% endblock %}
</head>
<body class="{% if author == 'linine' %}theme-linine{% endif %}">

{% include "cookie-banner.njk" %}
{% include "mobile-menu.njk" %}
{% include "nav.njk" %}
{% include "ticker.njk" %}

<main>
  {{ content | safe }}
</main>

{% include "footer.njk" %}

<script src="/js/main.js"></script>
{% block extrascripts %}{% endblock %}
</body>
</html>
