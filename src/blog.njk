---
layout: base.njk
title: Blog
description: Commentary on politics, technology, and the America worth defending. By Kayla Victoria Bennett and Linine.
permalink: /blog/
---

<!-- BLOG HERO -->
<div class="blog-index-hero">
  <div class="blog-index-hero__inner">
    <div class="blog-index-eyebrow">From the desk of Kayla Victoria Bennett</div>
    <h1 class="blog-index-title">The <em>Blog</em></h1>
    <p class="blog-index-sub">Commentary on politics, technology, and the America worth defending. Plus — Linine's takes, which Kayla does not always agree with.</p>
  </div>
</div>

<!-- FILTER TABS -->
<nav class="blog-filter" aria-label="Filter posts">
  <a href="/blog/" class="blog-filter-btn active">All</a>
  <a href="/blog/kayla/" class="blog-filter-btn">Kayla</a>
  <a href="/blog/linine/" class="blog-filter-btn linine-filter">Linine</a>
  <a href="/blog/category/politics/" class="blog-filter-btn">Politics</a>
  <a href="/blog/category/technology/" class="blog-filter-btn">Technology</a>
  <a href="/blog/category/culture/" class="blog-filter-btn">Culture</a>
  <a href="/blog/category/economy/" class="blog-filter-btn">Economy</a>
</nav>

<!-- POSTS -->
<div class="blog-posts">
  <div class="blog-posts-grid fade-in">
    {% for post in collections.posts %}
      {% if loop.first %}
      <!-- Featured post -->
      <a href="{{ post.url }}" class="blog-post-card featured {% if post.data.author == 'linine' %}linine-card{% endif %}">
        <div class="blog-post-cat">{{ post.data.category }} · Featured</div>
        <div class="blog-post-author-tag {% if post.data.author == 'linine' %}linine-tag{% else %}kayla-tag{% endif %}">
          {% if post.data.author == "linine" %}Linine{% else %}Kayla{% endif %}
        </div>
        <h2 class="blog-post-title">{{ post.data.title }}</h2>
        <p class="blog-post-excerpt">{{ post.data.description }}</p>
        <div class="blog-post-meta">
          <time datetime="{{ post.date | machineDate }}">{{ post.date | readableDate }}</time>
          <span>·</span>
          <span>{{ post.templateContent | readingTime }}</span>
        </div>
      </a>
      {% elif loop.index <= 3 %}
      <!-- Regular card -->
      <a href="{{ post.url }}" class="blog-post-card {% if post.data.author == 'linine' %}linine-card{% endif %}">
        <div class="blog-post-cat">{{ post.data.category }}</div>
        <div class="blog-post-author-tag {% if post.data.author == 'linine' %}linine-tag{% else %}kayla-tag{% endif %}">
          {% if post.data.author == "linine" %}Linine{% else %}Kayla{% endif %}
        </div>
        <h2 class="blog-post-title">{{ post.data.title }}</h2>
        <p class="blog-post-excerpt">{{ post.data.description }}</p>
        <div class="blog-post-meta">
          <time datetime="{{ post.date | machineDate }}">{{ post.date | readableDate }}</time>
          <span>·</span>
          <span>{{ post.templateContent | readingTime }}</span>
        </div>
      </a>
      {% endif %}
    {% endfor %}
  </div>

  <!-- All remaining posts as a list -->
  {% if collections.posts.length > 3 %}
  <div class="blog-posts-list fade-in" style="margin-top: 48px;">
    {% for post in collections.posts %}
      {% if loop.index > 3 %}
      <a href="{{ post.url }}" class="blog-list-item {% if post.data.author == 'linine' %}blog-list-item--linine{% endif %}">
        <div class="blog-list-left">
          <div class="blog-list-cat">{{ post.data.category }}</div>
          <h3 class="blog-list-title">{{ post.data.title }}</h3>
          <p class="blog-list-excerpt">{{ post.data.description }}</p>
        </div>
        <div class="blog-list-meta">
          <span class="blog-list-author-tag {% if post.data.author == 'linine' %}linine-tag{% else %}kayla-tag{% endif %}">
            {% if post.data.author == "linine" %}Linine{% else %}Kayla{% endif %}
          </span>
          <time datetime="{{ post.date | machineDate }}">{{ post.date | readableDate }}</time>
          <span>{{ post.templateContent | readingTime }}</span>
        </div>
      </a>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

</div>

<style>
.blog-posts-list {
  border-top: 0.5px solid var(--gray-light);
}
.blog-list-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 32px;
  padding: 28px 0;
  border-bottom: 0.5px solid var(--gray-light);
  text-decoration: none;
  color: inherit;
  transition: background 0.2s;
}
.blog-list-item:hover { background: var(--cream-dark); padding-left: 12px; padding-right: 12px; margin: 0 -12px; }
.blog-list-item--linine .blog-list-title { color: var(--linine-accent); }
.blog-list-left { flex: 1; }
.blog-list-cat {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.14em;
  color: var(--red);
  margin-bottom: 8px;
  text-transform: uppercase;
}
.blog-list-item--linine .blog-list-cat { color: var(--linine-accent); }
.blog-list-title {
  font-family: var(--font-serif);
  font-size: 20px;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.25;
  margin-bottom: 8px;
}
.blog-list-excerpt {
  font-size: 13px;
  color: var(--gray);
  line-height: 1.6;
}
.blog-list-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
  flex-shrink: 0;
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--gray);
  text-align: right;
  min-width: 120px;
}
.blog-post-author-tag, .blog-list-author-tag {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  padding: 3px 8px;
  border-radius: 2px;
}
.kayla-tag {
  background: var(--navy);
  color: var(--gold);
  border: 0.5px solid var(--gold);
}
.linine-tag {
  background: rgba(74,144,217,0.1);
  color: var(--linine-accent);
  border: 0.5px solid rgba(74,144,217,0.3);
}
</style>
